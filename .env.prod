# ============================================================
# Configuration FaxCloud Analyzer - Production
# ============================================================

# Votre nom de domaine (sans www)
DOMAIN=faxanalyser.fr

# Email pour les certificats SSL Let's Encrypt
ACME_EMAIL=votre-email@exemple.com

# Authentification dashboard Traefik (optionnel)
# Générez avec: htpasswd -nb admin votremotdepasse
TRAEFIK_AUTH=admin:$$apr1$$xyz...

# Timezone
TZ=Europe/Paris
